# Demo-bank public origin (this microservice URL)
DEMO_BANK_PUBLIC_ORIGIN=http://localhost:3002

# Your Visual Password backend API base
VISUAL_BACKEND_API_BASE_URL=http://localhost:3000/api

# Hosted visual verify UI origin (where /verify/:sessionToken exists)
VISUAL_VERIFY_ORIGIN=http://localhost:3001

# Optional explicit SaaS admin URL (defaults to VISUAL_VERIFY_ORIGIN/admin)
VISUAL_ADMIN_URL=http://localhost:3001/admin

# ── Partner API Credentials (Razorpay-style) ──────────────────────
# Generate key pair via dashboard: POST /api/partners/keys
# The response gives you key_id, key_secret, and webhook_secret (one-time)
VISUAL_PARTNER_ID=hdfc_bank

# key_id: public identifier (always visible in dashboard)
VISUAL_KEY_ID=key_test_vps_xxxxxxxxxxxx

# key_secret: private credential (shown only once on creation - KEEP THIS SAFE)
VISUAL_KEY_SECRET=secret_test_vps_xxxxxxxxxxxx

# Legacy fallback (used if VISUAL_KEY_SECRET is empty)
# VISUAL_API_KEY=dev-partner-key-change-me

# Cookie signing key for demo-bank local sessions (set strong random value in production)
DEMO_BANK_COOKIE_SECRET=change-demo-bank-cookie-secret

# Optional tunables
DEMO_BANK_SESSION_HOURS=12
DEMO_BANK_PENDING_MINUTES=10

# ── Agent Recovery Portal (Gmail SMTP) ────────────────────────────────────────
# Gmail address to send OTP & re-enrollment emails FROM
GMAIL_USER=someshsrichandan@gmail.com

# Gmail App Password (NOT your regular password)
# Steps: Google Account → Security → 2-Step Verification → App Passwords → Generate
GMAIL_APP_PASSWORD=hafhlmzahkatvpsw
# Display name shown in recovery emails
BANK_NAME=HDFC 
