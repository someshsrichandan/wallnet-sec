NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/fraudshield

# Required in production: use a strong random secret (minimum 32 chars).
TOKEN_SECRET=replace-with-a-long-random-secret-min-32-chars

# Comma-separated frontend origins allowed by CORS.
# Production should never use *.
CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# Comma-separated callback origins allowed for partner redirect callback.
# Production should use HTTPS origins only.
PARTNER_CALLBACK_ALLOWLIST=http://localhost:3001,http://localhost:3002

# Format: partnerId:apiKey,partnerId2:apiKey2
# Wildcard support: *:apiKey
# Replace dev key before production.
PARTNER_API_KEYS=hdfc_bank:dev-partner-key-change-me

# Proxy / ingress setup. Use 1 behind reverse proxy (Nginx/ALB/Cloudflare).
TRUST_PROXY=1

# Visual challenge tuning
VISUAL_SALT_VALUE=5
VISUAL_ALPHABET_GRID_SIZE=10
VISUAL_SESSION_TTL_MS=300000
VISUAL_MAX_ATTEMPTS=3

# Request body size for JSON and URL encoded payloads
JSON_LIMIT=20kb

# AI feature flags
AI_ENABLED=false
AI_PROVIDER=openai
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=1500
AI_MAX_RETRIES=1
AI_FRAUD_SHADOW_MODE=true
AI_FRAUD_ENFORCEMENT_MODE=false
AI_THREAT_SUMMARY_ENABLED=false
AI_PARTNER_ASSISTANT_ENABLED=false

# Gemini SDK example (uncomment to use Gemini)
# AI_ENABLED=true
# AI_PROVIDER=gemini
# AI_API_KEY=your-gemini-api-key
# AI_MODEL=gemini-2.0-flash
